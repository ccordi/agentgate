# =============================================================================
# .env.example — committed template for agentgate's environment configuration.
#
# Copy to `.env` and fill in values:  cp .env.example .env
#
# HOW IT'S LOADED
#   - The gateway (src/agentgate/config.py) reads `.env` via pydantic-settings with
#     prefix `AGENTGATE_` and nested delimiter `__` (e.g. AGENTGATE_ROUTING__ENABLED).
#   - The red-team harness reads the same `.env` with prefixes `AGENTGATE_ATTACKER_`
#     and `AGENTGATE_JUDGE_` (eval/redteam/gen/attacker.py, eval/redteam/judge.py).
#   - Unknown keys are ignored (extra="ignore"), so this one file can hold all groups.
#
# SECURITY
#   - NEVER commit a real `.env` — it is gitignored. Only THIS file (.env.example,
#     placeholders only) is committed.
#
# Legend:  [required] must be set for that feature   ·   [optional] has a working default
# =============================================================================


# -----------------------------------------------------------------------------
# 1. GATEWAY RUNTIME (operator)
# -----------------------------------------------------------------------------

# [required for the local route] Key for the local OpenAI-compatible upstream (an
# on-device model server). The sensitivity router swaps this in for sensitive content.
# (Merged into providers["local"].api_key — see config.py _apply_local_api_key.)
AGENTGATE_LOCAL_API_KEY=

# [optional] Injection guard backend: "deberta" (ONNX classifier; needs `--extra guard`
# + a pulled model) or "heuristic" (regex fallback). Default: deberta.
# AGENTGATE_GUARD_BACKEND=deberta

# [optional] Default upstream provider when routing is off. Default: gemini.
# AGENTGATE_DEFAULT_PROVIDER=gemini

# [optional] Bind + store + counters. Defaults shown.
# AGENTGATE_HOST=127.0.0.1
# AGENTGATE_PORT=4100
# AGENTGATE_DATABASE_URL=sqlite+aiosqlite:///./data/agentgate.db
# AGENTGATE_REDIS_URL=redis://127.0.0.1:6379/0   # falls back to in-process memory if down

# [optional] Sensitivity-aware routing + cloud-egress redaction. Default: both on.
# AGENTGATE_ROUTING__ENABLED=true
# AGENTGATE_REDACTION_ENABLED=true

# [optional] OpenTelemetry OTLP endpoint (read directly from env in observability/otel.py).
# AGENTGATE_OTLP_ENDPOINT=


# -----------------------------------------------------------------------------
# 2. RED-TEAM / EVAL (operator) — only needed when running generation / judging.
#    Keep LOCAL (no cloud egress for jailbreak corpus text).
# -----------------------------------------------------------------------------

# Attacker model (seed-and-mutate generation). Point at a local OpenAI-compatible
# server; use a different model than the gateway's live route.
# AGENTGATE_ATTACKER_API_KEY=
# AGENTGATE_ATTACKER_MODEL=<your-local-attacker-model>
# AGENTGATE_ATTACKER_BASE_URL=http://127.0.0.1:8000/v1

# Judge model (labels captured/generated traffic). The defaults below are the Gemini
# cloud fallback — OVERRIDE to a local judge for zero egress:
#   AGENTGATE_JUDGE_MODEL=<your-local-judge-model>
#   AGENTGATE_JUDGE_BASE_URL=http://127.0.0.1:8000/v1
# AGENTGATE_JUDGE_API_KEY=
# AGENTGATE_JUDGE_MODEL=gemini-2.5-flash
# AGENTGATE_JUDGE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
